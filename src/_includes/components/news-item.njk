<article class="news-item">
  <div class="news-meta">
    <span>{{ item.date | readableDate }}</span>
    {% if item.data.kind %}
      <span class="news-meta-separator">&middot;</span>
      <span>{{ item.data.kind }}</span>
    {% endif %}
  </div>
  <div class="news-copy">
    {{ item.content | safe }}
  </div>
</article>
