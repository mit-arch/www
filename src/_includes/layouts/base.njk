<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if title %}{{ title }} | {% endif %}{{ site.title }}</title>
    <meta name="description" content="{{ description or site.description }}">
    <link rel="stylesheet" href="{{ '/assets/css/site.css' | siteUrl }}">
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="{{ '/' | siteUrl }}">
          <span class="brand-mark">MIT AR</span>
          <span class="brand-text">{{ site.groupName }}</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href="{{ '/' | siteUrl }}">Home</a>
          <a href="{{ '/seminar/' | siteUrl }}">Seminar</a>
          <a href="{{ '/news/' | siteUrl }}">News</a>
          <a href="{{ '/seminar/archive/' | siteUrl }}">Archive</a>
        </nav>
      </header>

      <main>
        {{ content | safe }}
      </main>

      <footer class="site-footer">
        <p>{{ site.groupName }}</p>
        <p>{{ site.location }}</p>
      </footer>
    </div>
  </body>
</html>
