---
pagination:
  data: seminarTerms
  size: 1
  alias: term
permalink: "seminar/{{ term.slug }}/index.html"
layout: layouts/base.njk
eleventyExcludeFromCollections: true
---
<section class="page-header">
  <p class="eyebrow">Seminar</p>
  <h1>{{ term.label }}</h1>
  <p>{{ term.description or site.seminarBlurb }}</p>
</section>

<p class="page-link-row">
  <a class="text-link" href="{{ '/seminar/all.ics' | siteUrl }}">Subscribe to calendar</a>
</p>

{% if term.talks.length %}
  {% include "components/seminar-list.njk" %}
{% else %}
  <p>No talks are listed for this term.</p>
{% endif %}

<p class="page-link-row">
  <a class="text-link" href="{{ '/seminar/archive/' | siteUrl }}">Back to archive</a>
</p>
