---
layout: layouts/base.njk
title: Seminar
description: Current architecture seminar term
---
<section class="page-header">
  <p class="eyebrow">Seminar</p>
  <h1>{{ currentSeminar.label }}</h1>
  <p>{{ currentSeminar.description or site.seminarBlurb }}</p>
</section>

<p class="page-link-row">
  <a class="text-link" href="/seminar/all.ics">Subscribe to calendar</a>
</p>

{% if currentSeminar.talks.length %}
  {% set term = currentSeminar %}
  {% include "components/seminar-list.njk" %}
{% else %}
  <p>No talks have been posted for this term yet.</p>
{% endif %}

<p class="page-link-row">
  <a class="text-link" href="/seminar/archive/">Browse past terms</a>
</p>
