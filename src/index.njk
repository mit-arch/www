---
layout: layouts/base.njk
title: Home
description: MIT Architecture Research group homepage
---
<section class="hero">
  <div class="hero-copy">
    <p class="eyebrow">{{ site.hero.eyebrow }}</p>
    <h1>{{ site.hero.title }}</h1>
    <p class="hero-body">{{ site.hero.body }}</p>
  </div>
  <aside class="hero-panel">
    <p class="panel-label">Current seminar</p>
    <h2>{{ currentSeminar.label }}</h2>
    <p>{{ site.seminarBlurb }}</p>
    <a class="text-link" href="/seminar/">View this term</a>
  </aside>
</section>

<section class="content-grid">
  <div class="content-main">
    <section class="homepage-section" id="faculty">
      <div class="section-heading">
        <p class="eyebrow">People</p>
        <h2>Faculty</h2>
      </div>
      <div class="people-grid">
        {% for person in people.faculty %}
          {% set person = person %}
          {% include "components/person-card.njk" %}
        {% endfor %}
      </div>
    </section>

    <section class="homepage-section" id="students">
      <div class="section-heading">
        <h2>Students</h2>
      </div>
      <div class="people-grid">
        {% for person in people.students %}
          {% set person = person %}
          {% include "components/person-card.njk" %}
        {% endfor %}
      </div>
    </section>

    <section class="homepage-section" id="affiliates">
      <div class="section-heading">
        <h2>Affiliates</h2>
      </div>
      <div class="people-grid">
        {% for person in people.affiliates %}
          {% set person = person %}
          {% include "components/person-card.njk" %}
        {% endfor %}
      </div>
    </section>

    <section class="homepage-section" id="alumni">
      <div class="section-heading">
        <h2>Alumni</h2>
      </div>
      <div class="people-grid">
        {% for person in people.alumni %}
          {% set person = person %}
          {% include "components/person-card.njk" %}
        {% endfor %}
      </div>
    </section>
  </div>

  <aside class="content-rail">
    <section class="rail-card" id="news">
      <div class="section-heading">
        <p class="eyebrow">Updates</p>
        <h2>News</h2>
      </div>
      <div class="news-list">
        {% for item in (newsItems | sortedNews) | slice(0, site.newsHomepageCount) %}
          {% set item = item %}
          {% include "components/news-item.njk" %}
        {% endfor %}
      </div>
      <a class="text-link" href="/news/">All news</a>
    </section>

    <section class="rail-card" id="seminar-preview">
      <div class="section-heading">
        <p class="eyebrow">Seminar</p>
        <h2>{{ currentSeminar.label }}</h2>
      </div>
      <div class="seminar-preview-list">
        {% for talk in currentSeminar.talks | slice(0, 3) %}
          <article>
            <p>{{ talk.date | seminarDate }}</p>
            <h3>{{ talk.speaker }}</h3>
            <p>{{ talk.title }}</p>
          </article>
        {% endfor %}
      </div>
      <a class="text-link" href="/seminar/">Full schedule</a>
    </section>
  </aside>
</section>
